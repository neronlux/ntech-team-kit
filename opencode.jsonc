{
  "$schema": "https://opencode.ai/config.json",

  "instructions": ["rules/*.md"],

  "permission": {
    "skill": {
      "*": "allow",
      "thermo-nuclear-code-quality-review": "ask"
    }
  },

  "agent": {
    "ci-watcher": {
      "description": "Watch PR CI for the current branch and report pass/fail with relevant failure links.",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "gh *": "allow",
          "git *": "allow"
        }
      }
    },
    "thermo-nuclear-code-quality-review": {
      "description": "Deep maintainability & code-quality auditor (1k-line rule, code-judo, spaghetti). Tab-selectable via @ or via Task.",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow"
        }
      }
    }
  },

  "plugin": []
}
